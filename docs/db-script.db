-- =============================================================================
-- EDU-STRATEGY — Creación de tablas + datos de ejemplo
-- =============================================================================


-- -----------------------------------------------------------------------------
-- LIMPIEZA (ejecutar solo en desarrollo)
-- -----------------------------------------------------------------------------
DROP TABLE IF EXISTS hito CASCADE;
DROP TABLE IF EXISTS asignatura CASCADE;
DROP TABLE IF EXISTS semestre CASCADE;
DROP TABLE IF EXISTS estudiante CASCADE;
DROP TABLE IF EXISTS administrador CASCADE;
DROP TABLE IF EXISTS credencial CASCADE;
DROP TABLE IF EXISTS tipo_actividad CASCADE;


-- -----------------------------------------------------------------------------
-- 1. TIPO DE ACTIVIDAD — catálogo de clasificación de hitos
-- -----------------------------------------------------------------------------
CREATE TABLE tipo_actividad (
    id_tipo INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL UNIQUE,
    descripcion VARCHAR(200)
);


-- -----------------------------------------------------------------------------
-- 2. CREDENCIAL — autenticación (compartida por estudiante y administrador)
-- -----------------------------------------------------------------------------
CREATE TABLE credencial (
    id_credencial INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    email VARCHAR(100) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL,
    rol VARCHAR(20) NOT NULL CHECK (rol IN ('estudiante', 'administrador')),
    intentos_login INT NOT NULL DEFAULT 0,
    bloqueado BOOLEAN NOT NULL DEFAULT FALSE
);


-- -----------------------------------------------------------------------------
-- 3. ESTUDIANTE — perfil académico, vinculado a credencial
-- -----------------------------------------------------------------------------
CREATE TABLE estudiante (
    id_estudiante INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_credencial INT NOT NULL UNIQUE REFERENCES credencial(id_credencial) ON DELETE CASCADE,
    identificacion VARCHAR(20) NOT NULL UNIQUE,
    nombre_completo VARCHAR(100) NOT NULL,
    carrera VARCHAR(100) NOT NULL,
    semestre_actual INT  NOT NULL CHECK (semestre_actual BETWEEN 1 AND 12),
    fecha_ingreso DATE NOT NULL
);


-- -----------------------------------------------------------------------------
-- 4. ADMINISTRADOR — gestión de cuentas, vinculado a credencial
--    No tiene relación con semestre, asignatura ni hito
-- -----------------------------------------------------------------------------
CREATE TABLE administrador (
    id_administrador INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_credencial INT NOT NULL UNIQUE REFERENCES credencial(id_credencial) ON DELETE CASCADE,
    nombre_completo VARCHAR(100) NOT NULL
);


-- -----------------------------------------------------------------------------
-- 5. SEMESTRE — periodo académico del estudiante
--    FK apunta a estudiante: imposible asociar un semestre a un administrador
-- -----------------------------------------------------------------------------
CREATE TABLE semestre (
    id_semestre INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_estudiante INT NOT NULL REFERENCES estudiante(id_estudiante) ON DELETE CASCADE,
    nombre VARCHAR(30) NOT NULL,
    fecha_inicio DATE NOT NULL,
    fecha_fin DATE NOT NULL,
    activo BOOLEAN NOT NULL DEFAULT FALSE,
    CONSTRAINT chk_fechas_semestre CHECK (fecha_fin > fecha_inicio)
);


-- -----------------------------------------------------------------------------
-- 6. ASIGNATURA — materia dentro de un semestre
-- -----------------------------------------------------------------------------
CREATE TABLE asignatura (
    id_asignatura INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_semestre INT NOT NULL REFERENCES semestre(id_semestre) ON DELETE CASCADE,
    nombre VARCHAR(100) NOT NULL,
    nombre_docente VARCHAR(100) NOT NULL,
    CONSTRAINT uq_asignatura_semestre UNIQUE (id_semestre, nombre)
);


-- -----------------------------------------------------------------------------
-- 7. HITO — actividad evaluativa dentro de una asignatura
--    nota: DECIMAL(4,2) soporta valores como 3.90, 4.50 (escala 0.00–5.00)
-- -----------------------------------------------------------------------------
CREATE TABLE hito (
    id_hito INT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
    id_asignatura INT NOT NULL REFERENCES asignatura(id_asignatura) ON DELETE CASCADE,
    id_tipo_actividad INT NOT NULL REFERENCES tipo_actividad(id_tipo) ON DELETE RESTRICT,
    fecha_inicio DATE NOT NULL,
    fecha_cierre DATE NOT NULL,
    horas_dedicadas DECIMAL(5,2) NOT NULL CHECK (horas_dedicadas > 0),
    nota DECIMAL(4,2) CHECK (nota BETWEEN 0.00 AND 5.00),
    CONSTRAINT chk_fechas_hito CHECK (fecha_cierre >= fecha_inicio)
);


