{
  "extends": [
    "react-app",
    "react-app/jest",
    "plugin:prettier/recommended"
  ],

  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",

    "prettier/prettier": [
      "warn",
      {
        "endOfLine": "auto",
        "singleQuote": true,
        "semi": true
      }
    ]
  }
}